{
  "name": "buildarc",
  "version": "0.2.2",
  "description": "Your build story, recovered. Turn Claude Code sessions into tweet threads, LinkedIn posts, and build journals.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardomjq/buildarc.git"
  },
  "bugs": {
    "url": "https://github.com/leonardomjq/buildarc/issues"
  },
  "homepage": "https://github.com/leonardomjq/buildarc#readme",
  "keywords": [
    "buildarc",
    "claude-code",
    "build-in-public",
    "dev-journal",
    "cli",
    "ai-coding",
    "transcript",
    "twitter-thread",
    "linkedin",
    "content-creation",
    "developer-tools",
    "social-media"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "buildarc": "dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "tsc -p tsconfig.cli.json",
    "release:patch": "npm version patch && git push && git push --tags && npm publish",
    "release:minor": "npm version minor && git push && git push --tags && npm publish",
    "release:major": "npm version major && git push && git push --tags && npm publish"
  },
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.2",
    "lucide-react": "^0.574.0",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
